# ======================================================================
# Export Ignore — Excluded from `git archive` (tarball creation)
# ======================================================================

# Generated outputs and test artifacts
output/ export-ignore
tmp_real/ export-ignore
test_out/ export-ignore
temp_uploads/ export-ignore
.cache/ export-ignore
.pytest_cache/ export-ignore
__pycache__/ export-ignore

# Development and test files
test_*.py export-ignore
run_test_*.py export-ignore
.vscode/ export-ignore
.idea/ export-ignore
.env* export-ignore

# Repository metadata
.gitignore export-ignore
.gitattributes export-ignore
CHANGELOG.md export-ignore
ROADMAP.md export-ignore
TESTING.md export-ignore
TANDA_6_REVIEW.md export-ignore
TO_FIX.md export-ignore
INPUT_FIXING.md export-ignore
TROUBLESHOOTING.md export-ignore

# ======================================================================
# Line Ending Normalization
# ======================================================================

# Auto normalize to LF on all systems (cross-platform consistency)
* text=auto

# Explicitly text files for proper line ending handling
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
